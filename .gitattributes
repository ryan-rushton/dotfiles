# Default: auto-detect text files, normalize to LF in the repo and on checkout.
* text=auto eol=lf

# Shell scripts must be LF (Linux/macOS/WSL refuse CRLF shebangs).
*.sh        text eol=lf
*.zsh       text eol=lf
*.bash      text eol=lf

# Windows-native scripts must be CRLF.
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Binary files — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.gz        binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
